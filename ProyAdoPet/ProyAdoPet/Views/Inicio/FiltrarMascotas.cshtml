@model ProyAdoPet.ViewModel.FiltroMascotaVM

@{
    ViewData["Title"] = "Filtrar mascotas";
}

<!-- Encabezado -->
<div class="bg-light py-3 mb-4 border-bottom shadow-sm">
    <div class="container">
        <h4 class="fw-bold text-primary mb-0">
            <i class="bi bi-funnel-fill me-2"></i>Filtrar mascotas
        </h4>
        <p class="text-muted small mb-0">Encuentra la mascota ideal usando los filtros de búsqueda.</p>
    </div>
</div>

<div class="container pb-5">

    <!-- Formulario de filtros -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
            <form method="get" asp-action="FiltrarMascotas">
                <div class="row g-3 align-items-end">

                    <!-- Nombre -->
                    <div class="col-12 col-md-4">
                        <label class="form-label fw-semibold small text-muted">
                            <i class="bi bi-search me-1"></i>Nombre de la mascota
                        </label>
                        <input type="text"
                               name="nombre"
                               value="@Model.Nombre"
                               class="form-control rounded-3"
                               placeholder="Ej: Max, Luna...">
                    </div>

                    <!-- Edad -->
                    <div class="col-12 col-md-3">
                        <label class="form-label fw-semibold small text-muted">
                            <i class="bi bi-calendar3 me-1"></i>Edad
                        </label>
                        <input type="text"
                               name="edad"
                               value="@Model.Edad"
                               class="form-control rounded-3"
                               placeholder="Ej: 2 años">
                    </div>

                    <!-- Estado -->
                    <div class="col-12 col-md-3">
                        <label class="form-label fw-semibold small text-muted">
                            <i class="bi bi-heart-fill me-1"></i>Estado de adopción
                        </label>
                        @{
                            var estadoItems = Model.Estados.Select(e => new Microsoft.AspNetCore.Mvc.Rendering.SelectListItem
                            {
                                Value = e.Id.ToString(),
                                Text = e.EstadoNombre,
                                Selected = Model.EstadoId == e.Id
                            }).ToList();
                            estadoItems.Insert(0, new Microsoft.AspNetCore.Mvc.Rendering.SelectListItem { Value = "", Text = "-- Todos --" });
                        }
                        <select name="estadoId" class="form-select rounded-3" asp-items="estadoItems"></select>
                    </div>

                    <!-- Botones -->
                    <div class="col-12 col-md-2 d-flex gap-2">
                        <button type="submit" class="btn btn-primary rounded-3 flex-fill">
                            <i class="bi bi-search me-1"></i>Buscar
                        </button>
                        <a asp-action="FiltrarMascotas" class="btn btn-outline-secondary rounded-3">
                            <i class="bi bi-x-lg"></i>
                        </a>
                    </div>

                </div>
            </form>
        </div>
    </div>

    <!-- Resultados -->
    @if (!Model.BusquedaRealizada)
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-funnel" style="font-size: 3rem; opacity: 0.3;"></i>
            <p class="mt-3">Usa los filtros de arriba para encontrar mascotas.</p>
        </div>
    }
    else if (!Model.Resultados.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-emoji-frown text-muted" style="font-size: 3rem; opacity: 0.4;"></i>
            <p class="mt-3 text-muted">No se encontraron mascotas con esos criterios.</p>
            <a asp-action="FiltrarMascotas" class="btn btn-outline-primary rounded-pill px-4">
                <i class="bi bi-arrow-counterclockwise me-1"></i>Limpiar filtros
            </a>
        </div>
    }
    else
    {
        <p class="text-muted small mb-3">
            <i class="bi bi-check-circle-fill text-success me-1"></i>
            Se encontraron <strong>@Model.Resultados.Count()</strong> mascota(s).
        </p>

        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-3">
            @foreach (var item in Model.Resultados)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 rounded-4 mascota-card">

                        <div class="position-relative">
                            <img src="~/fotos/@item.FotoMascota"
                                 class="card-img-top rounded-top-4"
                                 alt="Foto de @item.Nombre"
                                 style="height: 180px; object-fit: cover;">

                            <span class="position-absolute bottom-0 start-0 m-2 badge rounded-pill shadow-sm
                                         @(item.Estado == 1 ? "bg-success" : "bg-secondary")"
                                  style="font-size: 0.7rem;">
                                @(item.Estado == 1 ? "Disponible" : "Adoptado")
                            </span>
                        </div>

                        <div class="card-body text-center p-2">
                            <h5 class="fw-bold text-dark mb-1">@item.Nombre</h5>
                            <p class="text-muted small mb-2">@item.Edad de edad</p>
                            <p class="card-text text-secondary small px-1"
                               style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                                @item.Descripcion
                            </p>
                        </div>

                        <div class="card-footer bg-transparent border-0 pb-3 pt-0">
                            <div class="d-grid">
                                <a asp-controller="Inicio" asp-action="DetalleMascota" asp-route-id="@item.Id"
                                   class="btn btn-primary btn-sm rounded-pill">
                                    <i class="bi bi-heart-fill me-1"></i>Conocer
                                </a>
                            </div>
                        </div>

                    </div>
                </div>
            }
        </div>
    }

    <!-- Botón volver -->
    <div class="mt-4">
        <a asp-action="Mascotas" class="btn btn-outline-secondary rounded-pill px-4">
            <i class="bi bi-arrow-left me-2"></i>Volver al catálogo
        </a>
    </div>

</div>

<style>
    .mascota-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .mascota-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.12) !important;
    }
</style>

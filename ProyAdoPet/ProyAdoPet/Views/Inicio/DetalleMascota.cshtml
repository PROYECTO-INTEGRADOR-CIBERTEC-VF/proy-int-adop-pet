@model ProyAdoPet.Models.Mascota

@{
    ViewData["Title"] = "Conociendo a " + Model.Nombre;
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-5 mb-4">
            <div class="card shadow-sm">
                <img src="~/fotos/@Model.FotoMascota" class="img-fluid rounded-start" alt="@Model.Nombre"
                     style="width: 100%; height: 450px; object-fit: cover;">
            </div>
        </div>

        <div class="col-md-7">
            <h1 class="display-4 fw-bold text-primary">@Model.Nombre</h1>
            <hr />

            <div class="mb-4">
                <h5 class="text-muted">Información General</h5>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item"><strong>Edad:</strong> @Model.Edad</li>
                    <li class="list-group-item">
                        <strong>Estado actual:</strong>
                        <span class="badge bg-success">Disponible para Adopción</span>
                    </li>
                </ul>
            </div>

            <div class="mb-4">
                <h5 class="text-muted">Su Historia</h5>
                <p class="lead text-dark">
                    @Model.Descripcion
                </p>
            </div>

            <div class="d-grid gap-2 d-md-flex justify-content-md-start mt-5">
                <a asp-action="Mascotas" class="btn btn-outline-secondary btn-lg px-4 me-md-2">
                    <i class="bi bi-arrow-left"></i> Volver
                </a>

                @if (User.Identity.IsAuthenticated)
                {
                    <a asp-action="Postular" asp-route-mascotaId="@Model.Id" class="btn btn-primary btn-lg px-5 shadow">
                        Postular para Adopción <i class="bi bi-heart-fill ms-2"></i>
                    </a>
                }
                else
                {
                    <a asp-controller="Login" asp-action="LogIn"
                       asp-route-returnUrl="@Url.Action("DetalleMascota", "Inicio", new { id = Model.Id })"
                       class="btn btn-primary btn-lg px-5 shadow">
                        Inicia sesión para adoptar <i class="bi bi-person-lock ms-2"></i>
                    </a>
                }
            </div>
        </div>
    </div>
</div>
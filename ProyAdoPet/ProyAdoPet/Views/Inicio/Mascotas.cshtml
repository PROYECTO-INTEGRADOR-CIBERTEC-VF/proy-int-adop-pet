@model IEnumerable<ProyAdoPet.Models.Mascota>

@{
    ViewData["Title"] = "Adopta un amigo";
}

<div class="hero-section py-5 mb-5 shadow-sm">
    <div class="container text-center text-white">
        <h1 class="display-5 fw-bold mb-2">¡Encuentra a tu nuevo mejor amigo!</h1>
        <p class="lead opacity-75">Hay cientos de patitas esperando por un hogar lleno de amor.</p>
    </div>
</div>

<div class="container">
    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-primary alert-dismissible fade show rounded-4 border-0 shadow-sm" role="alert">
            <i class="bi bi-info-circle-fill me-2"></i> @TempData["Mensaje"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 row-cols-xl-5 g-4 mb-5">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 pet-card-main border-0 shadow-sm">
                    <div class="img-zoom-container">
                        <img src="~/fotos/@item.FotoMascota"
                             class="card-img-top"
                             alt="Foto de @item.Nombre"
                             style="height: 200px; object-fit: cover;">

                        <span class="position-absolute top-0 end-0 m-2 badge rounded-pill @(item.Estado == 1 ? "bg-success" : "bg-secondary") shadow-sm py-2 px-3">
                            @(item.Estado == 1 ? "Disponible" : "Adoptado")
                        </span>
                    </div>

                    <div class="card-body p-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h5 class="fw-bold text-dark mb-0">@item.Nombre</h5>
                            <span class="age-tag">@item.Edad</span>
                        </div>

                        <p class="card-text text-muted small mb-0 text-truncate-2">
                            @item.Descripcion
                        </p>
                    </div>

                    <div class="card-footer bg-white border-0 pb-3 pt-0">
                        <div class="d-grid">
                            @if (item.Estado == 1)
                            {
                                <a asp-action="DetalleMascota" asp-route-id="@item.Id" class="btn btn-primary rounded-pill fw-bold py-2 shadow-sm">
                                    Conocer a @item.Nombre <i class="bi bi-heart-fill ms-1" style="font-size: 0.8rem;"></i>
                                </a>
                            }
                            else
                            {
                                <button disabled class="btn btn-outline-secondary rounded-pill fw-bold py-2">
                                    Ya tiene hogar
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
<style>
    .hero-section {
        background: linear-gradient(135deg, #0d6efd 0%, #003d99 100%);
        border-radius: 0 0 40px 40px;
    }

    .pet-card-main {
        border-radius: 15px;
        overflow: hidden;
        transition: all 0.3s cubic-bezier(.25,.8,.25,1);
        background: #fff;
    }

        .pet-card-main:hover {
            transform: translateY(-8px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.1) !important;
        }

    .img-zoom-container {
        overflow: hidden;
        position: relative;
    }

        .img-zoom-container img {
            transition: transform 0.5s ease;
        }

    .pet-card-main:hover .img-zoom-container img {
        transform: scale(1.1);
    }

    .age-tag {
        font-size: 0.75rem;
        background-color: #f8f9fa;
        color: #6c757d;
        padding: 3px 10px;
        border-radius: 10px;
        display: inline-block;
    }
</style>
@model IEnumerable<ProyAdoPet.ViewModel.SeguimientoListaVM>

<div class="container mt-4">
    <h2><i class="bi bi-calendar-check me-2"></i>Mascotas en Seguimiento</h2>
    <p class="text-muted">Gestione las visitas y controles de las mascotas adoptadas.</p>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover align-middle bg-white">
            <thead class="table-dark">
                <tr>
                    <th>Contrato</th>
                    <th>Adoptante / Mascota</th>
                    <th>Último Control</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>@item.CodigoContrato</strong></td>
                        <td>
                            <div class="fw-bold">@item.Adoptante</div>
                            <small class="text-muted">Mascota: @item.Mascota</small>
                        </td>
                        <td>
                            @(item.UltimoControl?.ToString("dd/MM/yyyy") ?? "Sin controles")
                        </td>
                        <td>
                            @if (item.DiasDesdeUltimoControl > 60)
                            {
                                <span class="badge bg-danger">Urgente (@item.DiasDesdeUltimoControl días)</span>
                            }
                            else if (item.DiasDesdeUltimoControl > 30)
                            {
                                <span class="badge bg-warning text-dark">Pendiente</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Al día</span>
                            }
                        </td>
                        <td>
                            <a asp-action="NuevoSeguimiento" asp-route-id="@item.SolicitudId" class="btn btn-primary btn-sm rounded-pill">
                                <i class="bi bi-plus-circle"></i> Registrar Visita
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

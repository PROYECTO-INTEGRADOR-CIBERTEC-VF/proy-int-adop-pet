@using ProyAdoPet.ViewModel
@model DetalleSeguimientoVM

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0">Seguimiento: @Model.MascotaNombre</h2>
            <p class="text-muted">Adoptante: @Model.AdoptanteNombre</p>
        </div>

        <button type="button"
                class="btn btn-warning rounded-pill px-4 shadow-sm"
                data-bs-toggle="modal"
                data-bs-target="#modalProgramar">
            <i class="bi bi-calendar-plus me-2"></i>Programar Nueva Visita
        </button>
    </div>

    @if (Model.Controles == null || !Model.Controles.Any())
    {
        <div class="alert alert-info border-0 shadow-sm">
            <i class="bi bi-info-circle me-2"></i>Aún no se han registrado visitas de control para esta adopción.
        </div>
    }
    else
    {
        <div class="timeline">
            @foreach (var control in Model.Controles)
            {
                <div class="card shadow-sm border-0 border-start border-4 @(control.EstadoVisita == "Pendiente" ? "border-warning" : "border-success") mb-3">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="fw-bold @(control.EstadoVisita == "Pendiente" ? "text-warning" : "text-success")">
                                <i class="bi @(control.EstadoVisita == "Pendiente" ? "bi-clock" : "bi-check-circle") me-1"></i>
                                Visita @control.TipoControl (@control.EstadoVisita)
                            </span>
                            <small class="text-muted">Ref: #@control.Id</small>
                        </div>

                        <div class="row">
                            <div class="col-md-8">
                                <p class="mb-1"><strong>Fecha Programada:</strong> @control.FechaProgramada.ToString("dd/MM/yyyy")</p>

                                @if (control.EstadoVisita == "Pendiente")
                                {
                                    <p class="text-muted small">Responsable asignado: @control.Responsable</p>
                                    <p class="card-text italic">"@control.ObservacionInicial"</p>
                                }
                                else
                                {
                                    <p class="mb-1"><strong>Fecha Realizada:</strong> @control.FechaRealizada?.ToString("dd/MM/yyyy")</p>
                                    <p class="mb-1">
                                        <strong>Resultado:</strong>
                                        <span class="badge @(control.Resultado == "Urgente" ? "bg-danger" : "bg-info text-dark")">@control.Resultado</span>
                                    </p>
                                    <p class="card-text">@control.Comentarios</p>
                                }
                            </div>

                            <div class="col-md-4 text-end align-self-center">
                                @if (control.EstadoVisita == "Pendiente")
                                {
                                    <button type="button" class="btn btn-sm btn-primary" onclick="prepararModal(@control.Id)">
                                        Registrar Resultado
                                    </button>
                                }
                                else if (!string.IsNullOrEmpty(control.FotoEvidencia))
                                {
                                    <img src="~/adop/seguimientos/@control.FotoEvidencia"
                                         class="img-thumbnail shadow-sm"
                                         style="width: 100px; height: 100px; object-fit: cover;"
                                         alt="Evidencia de visita" />
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <div class="mt-4">
        <a asp-action="Lista" class="btn btn-outline-secondary rounded-pill">
            <i class="bi bi-arrow-left"></i> Volver al listado
        </a>
    </div>
</div>


<div class="modal fade" id="modalProgramar" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <form asp-action="ProgramarVisita" method="post" class="modal-content">
            <input type="hidden" name="SolicitudId" value="@Model.SolicitudId" />

            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title"><i class="bi bi-calendar-plus me-2"></i>Programar Nueva Visita</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Fecha Programada</label>
                    <input type="date" name="FechaProgramada" class="form-control" required min="@DateTime.Now.ToString("yyyy-MM-dd")">
                </div>
                <div class="mb-3">
                    <label class="form-label">Tipo de Control</label>
                    <select name="TipoControl" class="form-control">
                        <option value="Presencial">Presencial</option>
                        <option value="Virtual">Virtual (WhatsApp/Video)</option>
                        <option value="Llamada">Llamada Telefónica</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Responsable</label>
                    <input type="text" name="Responsable" class="form-control" placeholder="Nombre del voluntario" required>
                </div>
                <div class="mb-3">
                    <label class="form-label">Observación Inicial / Objetivo</label>
                    <textarea name="ObservacionInicial" class="form-control" rows="2" placeholder="Ej: Verificar estado de vacunas..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="submit" class="btn btn-warning fw-bold">Guardar Programación</button>
            </div>
        </form>
    </div>
</div>

<div class="modal fade" id="modalResultado" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <form asp-action="CompletarVisita" method="post" enctype="multipart/form-data" class="modal-content">
            <input type="hidden" name="SeguimientoId" id="inputSeguimientoId" />
            <input type="hidden" name="SolicitudId" value="@Model.SolicitudId" />

            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="bi bi-journal-check me-2"></i>Registrar Resultado de Visita</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Fecha de Realización</label>
                    <input type="date" name="FechaRealizada" class="form-control" required value="@DateTime.Now.ToString("yyyy-MM-dd")">
                </div>
                <div class="mb-3">
                    <label class="form-label">Resultado</label>
                    <select name="Resultado" class="form-control">
                        <option value="Conforme">Conforme (Todo bien)</option>
                        <option value="Observaciones">Con Observaciones (Requiere atención)</option>
                        <option value="Urgente">Urgente (Riesgo para la mascota)</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Comentarios Finales</label>
                    <textarea name="Comentarios" class="form-control" rows="3" required placeholder="Describe lo que viste..."></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">Foto de Evidencia (Opcional)</label>
                    <input type="file" name="FotoFile" class="form-control">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="submit" class="btn btn-primary">Guardar Informe</button>
            </div>
        </form>
    </div>
</div>


<script>
    function prepararModal(id) {
        document.getElementById('inputSeguimientoId').value = id;
        var myModal = new bootstrap.Modal(document.getElementById('modalResultado'));
        myModal.show();
    }
</script>
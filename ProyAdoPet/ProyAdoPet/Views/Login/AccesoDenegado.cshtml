@{
    ViewData["Title"] = "Acceso Denegado";
    Layout = "_Layout";
}

<div class="container text-center" style="margin-top: 100px;">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <i class="bi bi-shield-lock-fill text-danger" style="font-size: 6rem;"></i>
            <h1 class="display-4 fw-bold text-dark">Acceso Restringido</h1>
            <p class="lead text-muted">
                Lo sentimos, no tienes los permisos necesarios para ver esta sección de <strong>AdoPet</strong>.
            </p>
            <hr />
            <div class="mt-4">
                <a href="/" class="btn btn-primary px-4">Volver al Inicio</a>
                <form method="post" action="/Login/Logout" class="d-inline">
                    <button type="submit" class="btn btn-outline-secondary px-4">Cambiar de Cuenta</button>
                </form>
            </div>
        </div>
    </div>
</div>
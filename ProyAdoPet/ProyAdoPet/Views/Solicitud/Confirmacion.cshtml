@{
    ViewData["Title"] = "Solicitud Enviada";
}

<div class="container mt-5 mb-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-4 p-5">
                <div class="card-body">
                    <div class="mb-4">
                        <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem;"></i>
                    </div>

                    <h2 class="fw-bold text-dark mb-3">¡Solicitud Enviada con Éxito!</h2>

                    <p class="text-secondary fs-5 mb-4">
                        Hola <strong>@ViewBag.Nombre</strong>, hemos recibido tu postulación correctamente.
                    </p>

                    <div class="bg-light p-3 rounded-3 mb-4 text-start">
                        <p class="mb-1 text-muted small"><i class="bi bi-clock me-2"></i><strong>Fecha y Hora:</strong> @ViewBag.Fecha</p>
                        <p class="mb-0 text-muted small"><i class="bi bi-shield-check me-2"></i><strong>Estado:</strong> Pendiente de Revisión</p>
                    </div>

                    <p class="text-muted mb-5">
                        El equipo del albergue revisará tu información. Te contactaremos al número brindado para coordinar la cita presencial si tu perfil es apto.
                    </p>

                    <div class="d-grid">
                        <a asp-controller="Inicio" asp-action="Mascotas" class="btn btn-primary btn-lg rounded-pill shadow">
                            <i class="bi bi-house-door me-2"></i> Volver al Inicio
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
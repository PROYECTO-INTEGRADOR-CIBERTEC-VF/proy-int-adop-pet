@using ProyAdoPet.Constants

<!DOCTYPE html>
<html lang="es" class="h-100">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ProyAdoPet</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ProyAdoPet.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>

<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-primary" href="/">
                    <i class="bi bi-paw-fill"></i> AdoPet
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarAdoPet">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarAdoPet">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Inicio"
                               asp-action="Index">Inicio</a>
                        </li>

                        @if (User.Identity.IsAuthenticated)
                        {
                            @if (User.IsInRole(RolesConstantes.Administrador))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-warning"
                                       asp-controller="AdminMascota"
                                       asp-action="ListadoMascotas">Gestión de Mascotas</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link"
                                       asp-controller="Solicitud"
                                       asp-action="Bandeja">Bandeja de entrada</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-warning"
                                       asp-controller="Seguimiento"
                                       asp-action="Lista">Adopciones en seguimiento</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link"
                                       asp-controller="Admin"
                                       asp-action="Registrar">Añadir co-administrador</a>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="nav-link"
                                       asp-controller="Inicio"
                                       asp-action="Mascotas">Mascotas</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link"
                                       asp-controller="Adopcion"
                                       asp-action="MisSolicitudes">Mis Solicitudes</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="/Home/SobreNosotros">Sobre Nosotros</a>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Inicio"
                                   asp-action="Mascotas">Mascotas</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Inico"
                                   asp-action="Acerca">Sobre Nosotros</a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item me-3 d-flex align-items-center">
                                <span class="text-light small">Hola, @User.Identity.Name</span>
                            </li>
                            <li class="nav-item">
                                <form method="post" action="/Login/Logout" class="d-inline">
                                    <button type="submit" class="btn btn-outline-light btn-sm">Cerrar Sesión</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item me-2">
                                <a class="btn btn-outline-light btn-sm" href="/Login/LogIn">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-light btn-sm text-dark" href="/Usuario/Register">Crear Cuenta</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="flex-grow-1 pt-3">
        <div class="container-fluid">
            @RenderBody()
        </div>
    </main>

    <footer class="mt-auto py-3 bg-dark text-secondary border-top border-secondary">
        <div class="container">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center">
                <div class="mb-2 mb-md-0">
                    <span class="text-light fw-bold">AdoPet</span>
                    <span class="ms-2 small text-muted">&copy; @DateTime.Now.Year Sitio web de adopción</span>
                </div>

                <div class="small d-flex align-items-center">
                    <span class="me-3">Lima, Perú</span>
                    <span class="d-none d-md-inline text-secondary opacity-50">|</span>
                    <span class="ms-3 text-muted">Proyecto de curso</span>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
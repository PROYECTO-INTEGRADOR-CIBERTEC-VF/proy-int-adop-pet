@model ProyAdoPet.Models.Mascota

@{
    ViewData["Title"] = "Registrar Nueva Mascota";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0 rounded-3">
                <div class="card-header bg-warning text-dark py-3">
                    <h4 class="mb-0 text-center"><i class="bi bi-paw-fill me-2"></i>Registrar Mascota</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="RegistrarMascota" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Nombre" class="form-label fw-bold">Nombre de la Mascota</label>
                            <input asp-for="Nombre" class="form-control" placeholder="Ejemplo: Toby" />
                            <span asp-validation-for="Nombre" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Edad" class="form-label fw-bold">Edad</label>
                                <input asp-for="Edad" class="form-control" placeholder="Ej: 2 años" />
                                <span asp-validation-for="Edad" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Estado" class="form-label fw-bold">Estado Inicial</label>
                                <select asp-for="Estado" asp-items="ViewBag.Estados" class="form-select">
                                    <option value="">-- Seleccione --</option>
                                </select>
                                <span asp-validation-for="Estado" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Descripcion" class="form-label fw-bold">Descripción / Historia</label>
                            <textarea asp-for="Descripcion" class="form-control" rows="3" placeholder="Describe brevemente a la mascota..."></textarea>
                            <span asp-validation-for="Descripcion" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-primary"><i class="bi bi-camera-fill me-1"></i> Foto de Perfil</label>
                            <input type="file" name="FotoArchivo" class="form-control" accept="image/*" />
                            <div class="form-text">Formatos permitidos: JPG, PNG. Máximo 2MB.</div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-warning fw-bold shadow-sm">
                                <i class="bi bi-check-circle-fill me-1"></i> Guardar Registro
                            </button>
                            <a asp-action="ListadoMascotas" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-1"></i> Volver al Listado
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
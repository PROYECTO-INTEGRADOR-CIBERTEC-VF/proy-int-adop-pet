@using ProyAdoPet.Constants
@model IEnumerable<ProyAdoPet.Models.Mascota>

@{
    ViewData["Title"] = "Gestión de Mascotas";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-dark fw-bold"><i class="bi bi-gear-fill me-2"></i>Gestión de Mascotas</h1>
        <a asp-action="Create" class="btn btn-primary shadow-sm">
            <i class="bi bi-plus-circle me-1"></i> Agregar Nueva Mascota
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>Foto</th>
                            <th>Nombre</th>
                            <th>Edad</th>
                            <th>Estado</th>
                            <th>Descripción</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted">
                                    <i class="bi bi-search d-block mb-2" style="font-size: 2rem;"></i>
                                    No se encontraron mascotas registradas.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold">#@item.Id</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(item.FotoMascota))
                                        {
                                            <img src="~/fotos/@item.FotoMascota" class="rounded shadow-sm" style="width: 50px; height: 50px; object-fit: cover;" alt="@item.Nombre" />
                                        }
                                        else
                                        {
                                            <div class="bg-secondary text-white rounded d-flex align-items-center justify-content-center shadow-sm" style="width: 50px; height: 50px;">
                                                <i class="bi bi-image"></i>
                                            </div>
                                        }
                                    </td>
                                    <td class="fw-bold">@item.Nombre</td>
                                    <td>@item.Edad años</td>
                                            <td>
                                        @if (item.Estado == EstadosConstantes.Disponible)
                                        {
                                            <span class="badge rounded-pill bg-success">Disponible</span>
                                        }
                                        else if (item.Estado == EstadosConstantes.Adoptado)
                                        {
                                            <span class="badge rounded-pill bg-info text-dark">Adoptado</span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill bg-warning text-dark">Estado #@item.Estado</span>
                                        }
                                    </td>
                                    <td>
                                        <small class="text-muted d-inline-block text-truncate" style="max-width: 200px;">
                                            @item.Descripcion
                                        </small>
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group" role="group">
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm" title="Editar">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm" title="Eliminar">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
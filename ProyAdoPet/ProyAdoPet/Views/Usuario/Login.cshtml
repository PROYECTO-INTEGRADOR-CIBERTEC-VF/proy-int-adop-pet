@{
    ViewData["Title"] = "Iniciar Sesión";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-4">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-dark text-white text-center py-4 rounded-top-4">
                    <h2 class="fw-bold mb-0"><i class="bi bi-shield-lock-fill text-primary"></i> AdoPet</h2>
                    <p class="small mb-0 opacity-75">Ingresa tus credenciales</p>
                </div>
                <div class="card-body p-4">

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger py-2 small">
                            <i class="bi bi-exclamation-circle me-2"></i> @ViewBag.Error
                        </div>
                    }

                    @if (TempData["Mensaje"] != null)
                    {
                        <div class="alert alert-success py-2 small">
                            <i class="bi bi-check-circle me-2"></i> @TempData["Mensaje"]
                        </div>
                    }

                    <form asp-action="Login" method="post">
                        <div class="form-floating mb-3">
                            <input type="email" name="correo" class="form-control" id="correo" placeholder="correo@ejemplo.com" required>
                            <label for="correo">Correo electrónico</label>
                        </div>
                        <div class="form-floating mb-4">
                            <input type="password" name="clave" class="form-control" id="clave" placeholder="Contraseña" required>
                            <label for="clave">Contraseña</label>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold">
                                Entrar
                            </button>
                        </div>
                    </form>
                </div>
                <div class="card-footer bg-light text-center py-3 rounded-bottom-4">
                    <span class="text-muted small">¿No tienes cuenta? </span>
                    <a asp-action="Register" class="text-primary fw-bold text-decoration-none small">Regístrate aquí</a>
                </div>
            </div>
        </div>
    </div>
</div>
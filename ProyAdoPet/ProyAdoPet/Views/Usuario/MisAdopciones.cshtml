@using ProyAdoPet.ViewModel
@model List<MisMascotasVM>

@{
    ViewData["Title"] = "Mis Mascotas Adoptadas";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi- house-heart text-danger me-2"></i>Mis Mascotas</h2>
        <span class="badge bg-secondary">@Model.Count Mascota(s)</span>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info text-center shadow-sm">
            <i class="bi bi-info-circle fs-4 d-block mb-2"></i>
            Todavía no tienes mascotas registradas bajo tu adopción.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm border-0">
                        <img src="~/fotos/@item.FotoMascota"
                             class="card-img-top"
                             style="height: 220px; object-fit: cover;"
                             alt="@item.MascotaNombre">

                        <div class="card-body">
                            <h5 class="card-title fw-bold text-primary">@item.MascotaNombre</h5>
                            <p class="text-muted small mb-3">
                                <i class="bi bi-hash"></i> Contrato: @item.CodigoContrato
                            </p>

                            <div class="p-2 rounded @(item.ProximaVisita.HasValue ? "bg-warning-subtle border border-warning" : "bg-light border")">
                                <small class="d-block text-uppercase fw-bold text-muted" style="font-size: 0.7rem;">
                                    Próxima Visita de Seguimiento:
                                </small>
                                <span class="fw-bold text-dark">
                                    <i class="bi bi-calendar-event me-1"></i>
                                    @(item.ProximaVisita.HasValue ? item.ProximaVisita.Value.ToString("dd/MM/yyyy") : "Pendiente de programar")
                                </span>
                            </div>
                        </div>

                        <div class="card-footer bg-white border-0 pb-3">
                            <a asp-action="MiMascotaDetalle" asp-route-id="@item.SolicitudId"
                               class="btn btn-primary w-100 rounded-pill shadow-sm">
                                Ver Seguimiento
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>